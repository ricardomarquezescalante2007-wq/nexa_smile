# ==========================
# CONSULTAS DE CITAS
# ==========================

def obtener_citas():
    conexion = obtener_conexion()
    cursor = conexion.cursor()

    cursor.execute("""
        SELECT
            citas.id_cita,
            pacientes.nombre || ' ' || pacientes.apellido,
            odontologos.nombre,
            citas.fecha,
            citas.hora,
            citas.motivo,
            citas.estado
        FROM citas
        INNER JOIN pacientes
            ON citas.id_paciente = pacientes.id_paciente
        INNER JOIN odontologos
            ON citas.id_odontologo = odontologos.id_odontologo
    """)

    citas = cursor.fetchall()

    conexion.close()
    return citas


def buscar_cita(id_cita):
    conexion = obtener_conexion()
